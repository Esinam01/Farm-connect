PORT=5050
PUBLIC_BASE_URL=http://localhost:5050

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=farmconnect
DB_USER=postgres
DB_PASSWORD=postgres

# SMTP Configuration (Optional - for admin approval emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=FarmConnect Admin <your-email@gmail.com>

# Paystack Payment Gateway (Card Payments)
# Get keys from: https://dashboard.paystack.co
# Test Mode Keys shown below - replace with your actual keys
PAYSTACK_SECRET_KEY=your_paystack_test_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here

# Ghana Mobile Money Configuration (MTN, AirtelTigo, Vodafone)
# Configure with your mobile money provider API credentials
MOMO_API_USER=your_api_user
MOMO_API_KEY=your_api_key
MOMO_PRIMARY_KEY=your_primary_key
MOMO_SECONDARY_KEY=your_secondary_key
